#include <SPI.h>
#include <MFRC522.h>
#include <Servo.h>

// PIN DEFINITIONS
#define RST_PIN 9
#define SS_PIN 10

//  Main Gate Servo (SG90)
#define SERVO_PIN 8

//  Emergency Servo (MG995)
#define EMERGENCY_SERVO_PIN 7

// LEDs
#define LED_PIN1 5
#define LED_PIN2 6
#define LED_PIN_GAS 4

// Buzzer
#define BUZZER_PIN 3

// Gas Sensor
#define GAS_SENSOR_PIN A0

//  Vibration Sensor
#define VIBRATION_SENSOR_PIN 2

#define GAS_THRESHOLD 800
#define RATE_PER_HOUR 2.00

MFRC522 mfrc522(SS_PIN, RST_PIN); //MFRC522 is a class and mfrc522 is object created 

//  Main Gate Servo
Servo gateServo;

//  Emergency Servo
Servo emergencyServo;

//  VALID RFID CARDS 
byte validUID1[] = {0x40, 0xD9, 0x69, 0x1B};
byte validUID2[] = {0xE2, 0x3C, 0xC9, 0x1A};

// PARKING STATUS 
bool carParked1 = false;
bool carParked2 = false;

unsigned long entryTime1 = 0;
unsigned long entryTime2 = 0;

float cost1 = 0.00;
float cost2 = 0.00;


// SETUP it implemented only once system started 

void setup() {

  Serial.begin(9600);

  SPI.begin();
  mfrc522.PCD_Init(); //function defined in the class runs the rfid 

  //  Main Gate Servo
  gateServo.attach(SERVO_PIN);
  gateServo.write(0);

  //  Emergency Servo
  emergencyServo.attach(EMERGENCY_SERVO_PIN);

  //  Stop servo
  emergencyServo.write(92); // rotation speed 

  pinMode(LED_PIN1, OUTPUT);
  pinMode(LED_PIN2, OUTPUT);
  pinMode(LED_PIN_GAS, OUTPUT);

  pinMode(BUZZER_PIN, OUTPUT);

  pinMode(GAS_SENSOR_PIN, INPUT);

  // Vibration Sensor
  pinMode(VIBRATION_SENSOR_PIN, INPUT);

  Serial.println("=== SMART SAFETY PARKING SYSTEM ===");
  Serial.println("Scan RFID card to enter or exit");
}
// LOOP

void loop() {

  // Check Gas Sensor
  checkGas();

  // Check Earthquake
  checkVibration();

  // RFID Detection
  if (!mfrc522.PICC_IsNewCardPresent() ||
      !mfrc522.PICC_ReadCardSerial()) {

    return; // will exit the loop (nothing happens)
  }
//making sure of size of card entered
  byte* uid = mfrc522.uid.uidByte;
  byte uidSize = mfrc522.uid.size;


  if (uidSize == 4 &&
      memcmp(uid, validUID1, 4) == 0) { //memcmp memory compare compares of arrays size 

    handleCard(1);

  } else if (uidSize == 4 &&
             memcmp(uid, validUID2, 4) == 0) {

    handleCard(2);

  } else {

    Serial.println("⚠ Invalid card detected.");
  }

  mfrc522.PICC_HaltA(); // stops scanning between the card and rfid 
  mfrc522.PCD_StopCrypto1(); //stops the encoding between 
}


// HANDLE RFID CARD

void handleCard(int cardNumber) { // handlecard (1 or 2)

  bool &carParked = // & is call by reference for 1 or 2 
    (cardNumber == 1) ? carParked1 : carParked2;

  unsigned long &entryTime =
    (cardNumber == 1) ? entryTime1 : entryTime2;

  float &cost =
    (cardNumber == 1) ? cost1 : cost2;

  openGate();

  if (!carParked) {

    carParked = true;

    entryTime = millis();

    cost = 0.0;

    if (cardNumber == 1) {

      blinkLED(LED_PIN1);

    } else {

      blinkLED(LED_PIN2);
    }

    Serial.print("✅ Card ");
    Serial.print(cardNumber);
    Serial.println(" - Entry Recorded");

  } else {

    carParked = false;

    unsigned long durationMillis =
      millis() - entryTime;

    float durationHours =
      (float)durationMillis /
      (1000.0 * 60.0 * 60.0);

    cost = durationHours * RATE_PER_HOUR;

    Serial.print("⏱ Card ");
    Serial.print(cardNumber);

    Serial.print(" - Duration: ");
    Serial.print(durationHours, 2);

    Serial.print(" hours | 💵 Cost: $");
    Serial.println(cost, 2);
  }

  Serial.println("------------------------------");
  Serial.println("Scan RFID card to enter or exit");
}


// MAIN GATE FUNCTION

void openGate() {

  gateServo.write(90);

  Serial.println(" Main Gate Opening...");

  delay(3000);

  gateServo.write(0);

  Serial.println(" Main Gate Closed.");
}


// LED BLINK FUNCTION

void blinkLED(int ledPin) {

  for (int i = 0; i < 5; i++) {

    digitalWrite(ledPin, HIGH);
    delay(500);

    digitalWrite(ledPin, LOW);
    delay(500);
  }
}


// GAS / EMERGENCY SYSTEM

void checkGas() {

  int gasLevel = analogRead(GAS_SENSOR_PIN);

  if (gasLevel > GAS_THRESHOLD) {

    Serial.print("⚠ GAS DETECTED! LEVEL: ");
    Serial.println(gasLevel);

    //  OPEN EMERGENCY EXIT
    emergencyServo.write(180);

    delay(560);

    emergencyServo.write(92);

    Serial.println(" Emergency Exit Opened!");

    //  Buzzer + GAS LED ONLY
    for (int i = 0; i < 17; i++) {

      digitalWrite(BUZZER_PIN, HIGH);

      digitalWrite(LED_PIN_GAS, HIGH);

      delay(300);

      digitalWrite(BUZZER_PIN, LOW);

      digitalWrite(LED_PIN_GAS, LOW);

      delay(300);
    }

    //  CLOSE EMERGENCY EXIT
    emergencyServo.write(0);

    delay(560);

    emergencyServo.write(92);

    Serial.println(" Emergency Exit Closed.");
  }
}


// VIBRATION / EARTHQUAKE SYSTEM

void checkVibration() {

  int vibrationState = digitalRead(VIBRATION_SENSOR_PIN);

  if (vibrationState == LOW) {

    Serial.println(" EARTHQUAKE DETECTED!");

    //  OPEN EMERGENCY EXIT
    emergencyServo.write(180);

    delay(560);

    emergencyServo.write(92);

    Serial.println(" Emergency Exit Opened!");

    //  Alarm
    for (int i = 0; i < 17; i++) {

      digitalWrite(BUZZER_PIN, HIGH);

      digitalWrite(LED_PIN_GAS, HIGH);

      delay(300);

      digitalWrite(BUZZER_PIN, LOW);

      digitalWrite(LED_PIN_GAS, LOW);

      delay(300);
    }

    //  CLOSE EMERGENCY EXIT
    emergencyServo.write(0);

    delay(560);

    emergencyServo.write(92);

    Serial.println(" Emergency Exit Closed.");

    delay(1000);
  }
}
