  async function fetchPayroll() {
    try {
      document.getElementById('pay-body').innerHTML = '<tr><td colspan="5" style="text-align:center;">جاري الحساب... ⏳</td></tr>';
      
      const r = await fetch(`${SUPABASE_URL}/rest/v1/attendance_logs?select=*&order=created_at.asc&limit=2000`, {
        headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
      });
      const data = await r.json();

      let stats = {};
      let currentMonth = new Date().getMonth(); 
      let monthNames = ["يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو", "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر"];
      
      document.getElementById('pay-title').innerHTML = `💰 تقرير رواتب شهر ${monthNames[currentMonth]}`;

      data.forEach(l => {
        let dateObj = new Date(l.created_at);
        if(dateObj.getMonth() !== currentMonth) return; 

        let name = l.name || l.employee_name;
        if(!name) return;

        if(!stats[name]) {
          stats[name] = { attendedDates: new Set(), totalMinutes: 0, penalty: 0 };
        }

        let dateStr = dateObj.toLocaleDateString('en-US');

        if(l.action === 'Check-in') {
          if(!stats[name].attendedDates.has(dateStr)) {
            stats[name].attendedDates.add(dateStr);
            
            let h = dateObj.getHours();
            let m = dateObj.getMinutes();
            let lateMinutes = 0;
            
            if(h >= 8) {
              lateMinutes = ((h - 8) * 60) + m; 
            }

            if(lateMinutes > 0 && lateMinutes < 120) {
              stats[name].penalty += 50; 
            } else if (lateMinutes >= 120) {
              stats[name].penalty += 100;
            }
          }
        } 
        else if (l.action === 'Check-out' && l.duration) {
          let parts = l.duration.split(':');
          if(parts.length === 2) {
            stats[name].totalMinutes += (parseInt(parts[0]) * 60) + parseInt(parts[1]);
          }
        }
      });

      let html = '';
      for(let emp in stats) {
        let s = stats[emp];
        let days = s.attendedDates.size;
        let hrs = Math.floor(s.totalMinutes / 60);
        let mins = s.totalMinutes % 60;
        
        let baseSalary = days * 200;
        let netSalary = baseSalary - s.penalty; 

