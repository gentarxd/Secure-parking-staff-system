void setup() {
  Serial.begin(115200); delay(1000);
  
  pinMode(LED_PIN, OUTPUT); // تفعيل اللمبة المدمجة
  
  WiFi.begin(ssid, password); Serial.print("جاري الاتصال");
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\n✓ WiFi متصل!"); Serial.print("🌐 افتح المتصفح على: http://"); Serial.println(WiFi.localIP());
  
  configTime(2 * 3600, 0, "pool.ntp.org");
  time_t now = 0; while (now < 100000) { delay(500); time(&now); }
  Serial.println("✓ الوقت متزامن!"); 
  
  setupRoutes(); 
  Serial.println("✅ النظام جاهز - أدخل الكود:");
}

// ==================== Loop ====================
void loop() {
  server.handleClient();
  
  char key = keypad.getKey(); if (!key) return;
  if (key == '*') { enteredCode = ""; Serial.println("\n[مسح]"); return; }
  if (key == 'A' || key == 'B' || key == 'C' || key == 'D' || key == '#') return;
  
  enteredCode += key; Serial.print("*");
  if ((int)enteredCode.length() == CODE_LENGTH) { 
    Serial.println(); 
    checkCode(enteredCode); 
    enteredCode = ""; 
  }
}
