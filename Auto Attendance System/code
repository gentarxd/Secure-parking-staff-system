// ==================== متغيرات ====================
String enteredCode = "";
const int CODE_LENGTH = 4;

String statusJSON() {
  String j = "["; bool first = true;
  for (int i = 0; i < MAX_EMP; i++) {
    if (!employees[i].active) continue;
    if (!first) j += ",";
    j += "{\"name\":\"" + employees[i].name + "\",\"code\":\"" + employees[i].code + "\",\"isIn\":" + (employees[i].isIn ? "true" : "false") + ",\"checkInTime\":" + String((long)employees[i].checkInTime) + "}";
    first = false;
  }
  return j + "]";
}

void setupRoutes() {
  server.on("/", HTTP_GET, []() { server.send(200, "text/html; charset=utf-8", getHTML()); });
  server.on("/api/status", HTTP_GET, []() { server.sendHeader("Access-Control-Allow-Origin", "*"); server.send(200, "application/json", statusJSON()); });
  server.on("/api/admin/verify", HTTP_GET, []() { server.send(200, "application/json", (server.arg("pass") == ADMIN_PASS) ? "{\"ok\":true}" : "{\"ok\":false}"); });
  server.on("/api/admin/add", HTTP_GET, []() {
    if (server.arg("pass") != ADMIN_PASS) { server.send(403, "application/json", "{\"ok\":false}"); return; }
    String name = server.arg("name"); String code = server.arg("code");
    for (int i = 0; i < MAX_EMP; i++) {
      if (!employees[i].active) { employees[i] = {name, code, false, 0, true}; NUM_EMP++; server.send(200, "application/json", "{\"ok\":true,\"msg\":\"تمت الإضافة ✅\"}"); return; }
    }
  });
  server.on("/api/admin/remove", HTTP_GET, []() {
    if (server.arg("pass") != ADMIN_PASS) { server.send(403, "application/json", "{\"ok\":false}"); return; }
    String code = server.arg("code");
    for (int i = 0; i < MAX_EMP; i++) {
      if (employees[i].active && employees[i].code == code) { employees[i].active = false; NUM_EMP--; server.send(200, "application/json", "{\"ok\":true,\"msg\":\"تم الحذف ✅\"}"); return; }
    }
  });
  server.begin(); Serial.println("✓ Web Server شغال!");
}

String calcDuration(time_t in, time_t out) {
  long d = max(0L, (long)(out - in)); char buf[10];
  sprintf(buf, "%02d:%02d", (int)(d / 3600), (int)((d % 3600) / 60)); return String(buf);
}

// ==================== دوال الإضاءة (LED) ====================
void successBlink() {
  for (int i = 0; i < 3; i++) { digitalWrite(LED_PIN, HIGH); delay(100); digitalWrite(LED_PIN, LOW); delay(100); }
}

void failBlink() {
  digitalWrite(LED_PIN, HIGH); delay(1000); digitalWrite(LED_PIN, LOW);
}

// ==================== الإرسال لـ N8N و Supabase ====================
void sendToN8N(String name, String code, String action, String dur) {
  if (WiFi.status() != WL_CONNECTED) return;
  HTTPClient http; http.begin(webhook_url); http.addHeader("Content-Type", "application/json");
  int res = http.POST("{\"name\":\"" + name + "\",\"code\":\"" + code + "\",\"action\":\"" + action + "\",\"duration\":\"" + dur + "\"}");
  Serial.printf(res > 0 ? "✓ n8n OK (%d)\n" : "✗ n8n Error: %d\n", res); http.end();
}

void sendToSupabase(String name, String code, String action, String dur) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure(); HTTPClient http;
  http.begin(client, SUPABASE_PROJECT_URL + "/rest/v1/attendance_logs");
  http.addHeader("Content-Type", "application/json"); http.addHeader("apikey", SUPABASE_ANON_KEY);
  http.addHeader("Authorization", "Bearer " + SUPABASE_ANON_KEY); http.addHeader("Prefer", "return=minimal");
  int res = http.POST("{\"name\":\"" + name + "\",\"code\":\"" + code + "\",\"action\":\"" + action + "\",\"duration\":\"" + dur + "\"}");
  Serial.printf(res > 0 ? "✓ Supabase DB OK (%d)\n" : "✗ Supabase DB Error: %d\n", res); http.end();
}

// ==================== التحقق من الكود ====================
void checkCode(String code) {
  for (int i = 0; i < MAX_EMP; i++) {
    if (!employees[i].active || employees[i].code != code) continue;
    
    employees[i].isIn = !employees[i].isIn;
    String action = employees[i].isIn ? "Check-in" : "Check-out";
    time_t now; time(&now); String dur = "";
    
    if (employees[i].isIn) { 
      employees[i].checkInTime = now; 
      Serial.printf("✓ %s - دخول\n", employees[i].name.c_str()); 
    } else { 
      dur = calcDuration(employees[i].checkInTime, now); 
      Serial.printf("✓ %s - خروج | %s\n", employees[i].name.c_str(), dur.c_str()); 
    }
    
    sendToN8N(employees[i].name, employees[i].code, action, dur);
    sendToSupabase(employees[i].name, employees[i].code, action, dur);
    
    successBlink(); // وميض النجاح
    
    Serial.println("-------------------------\nأدخل الكود:"); return;
  }
  Serial.println("✗ كود خاطئ!");
  failBlink(); // وميض الفشل
}

